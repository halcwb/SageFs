{
  "name": "sagefs",
  "displayName": "SageFs — Live F# Development",
  "description": "Send F# code to SageFs for instant evaluation, type-checking, and hot reload.",
  "version": "0.5.506",
  "publisher": "sagefs",
  "license": "MIT",
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/WillEhrendreich/SageFs"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages",
    "Testing",
    "Linters"
  ],
  "keywords": [
    "fsharp",
    "f#",
    "repl",
    "interactive",
    "hot-reload",
    "mcp"
  ],
  "extensionKind": [
    "workspace"
  ],
  "activationEvents": [
    "onLanguage:fsharp",
    "workspaceContains:**/*.fsproj",
    "workspaceContains:**/*.sln",
    "workspaceContains:**/*.slnx",
    "onCommand:sagefs.start",
    "onCommand:sagefs.stop",
    "onCommand:sagefs.restart",
    "onCommand:sagefs.openDashboard"
  ],
  "main": "./dist/Extension.js",
  "contributes": {
    "commands": [
      {
        "command": "sagefs.eval",
        "title": "SageFs: Evaluate Selection / Line",
        "icon": "$(play)"
      },
      {
        "command": "sagefs.evalFile",
        "title": "SageFs: Evaluate Entire File"
      },
      {
        "command": "sagefs.evalRange",
        "title": "SageFs: Evaluate Code Block"
      },
      {
        "command": "sagefs.start",
        "title": "SageFs: Start Daemon"
      },
      {
        "command": "sagefs.stop",
        "title": "SageFs: Stop Daemon"
      },
      {
        "command": "sagefs.restart",
        "title": "SageFs: Restart Daemon"
      },
      {
        "command": "sagefs.openDashboard",
        "title": "SageFs: Open Dashboard"
      },
      {
        "command": "sagefs.resetSession",
        "title": "SageFs: Reset Session"
      },
      {
        "command": "sagefs.hardReset",
        "title": "SageFs: Hard Reset (Rebuild)"
      },
      {
        "command": "sagefs.createSession",
        "title": "SageFs: Create Session"
      },
      {
        "command": "sagefs.switchSession",
        "title": "SageFs: Switch Session"
      },
      {
        "command": "sagefs.stopSession",
        "title": "SageFs: Stop Session"
      },
      {
        "command": "sagefs.clearResults",
        "title": "SageFs: Clear Inline Results"
      },
      {
        "command": "sagefs.cycleDensity",
        "title": "SageFs: Cycle Density (Full → Normal → Minimal)"
      },
      {
        "command": "sagefs.hotReloadToggle",
        "title": "SageFs: Toggle Hot Reload for File"
      },
      {
        "command": "sagefs.hotReloadWatchAll",
        "title": "SageFs: Watch All Files",
        "icon": "$(check-all)"
      },
      {
        "command": "sagefs.hotReloadUnwatchAll",
        "title": "SageFs: Unwatch All Files",
        "icon": "$(close-all)"
      },
      {
        "command": "sagefs.hotReloadRefresh",
        "title": "SageFs: Refresh Hot Reload",
        "icon": "$(refresh)"
      },
      {
        "command": "sagefs.hotReloadToggleDirectory",
        "title": "SageFs: Toggle Directory Hot Reload"
      },
      {
        "command": "sagefs.sessionContextRefresh",
        "title": "SageFs: Refresh Session Context",
        "icon": "$(refresh)"
      },
      {
        "command": "sagefs.enableLiveTesting",
        "title": "SageFs: Enable Live Testing"
      },
      {
        "command": "sagefs.disableLiveTesting",
        "title": "SageFs: Disable Live Testing"
      },
      {
        "command": "sagefs.runTests",
        "title": "SageFs: Run All Tests"
      },
      {
        "command": "sagefs.setRunPolicy",
        "title": "SageFs: Set Test Run Policy"
      },
      {
        "command": "sagefs.showHistory",
        "title": "SageFs: Show Recent Events"
      },
      {
        "command": "sagefs.showCallGraph",
        "title": "SageFs: Show Test Call Graph"
      },
      {
        "command": "sagefs.showBindings",
        "title": "SageFs: Show FSI Bindings"
      },
      {
        "command": "sagefs.showTestTrace",
        "title": "SageFs: Show Test Trace"
      },
      {
        "command": "sagefs.exportSession",
        "title": "SageFs: Export Session as .fsx"
      },
      {
        "command": "sagefs.sessionMenu",
        "title": "SageFs: Session Menu"
      },
      {
        "command": "sagefs.sessionsRefresh",
        "title": "SageFs: Refresh Sessions",
        "icon": "$(refresh)"
      },
      {
        "command": "sagefs.switchToSession",
        "title": "Switch To",
        "icon": "$(arrow-right)"
      },
      {
        "command": "sagefs.stopSessionInline",
        "title": "Stop",
        "icon": "$(debug-stop)"
      },
      {
        "command": "sagefs.resetSessionInline",
        "title": "Reset",
        "icon": "$(debug-restart)"
      },
      {
        "command": "sagefs.evalAdvance",
        "title": "SageFs: Evaluate & Advance",
        "icon": "$(run-below)"
      },
      {
        "command": "sagefs.evalAllBlocks",
        "title": "SageFs: Evaluate All Blocks",
        "icon": "$(run-all)"
      },
      {
        "command": "sagefs.nextBlock",
        "title": "SageFs: Next Code Block"
      },
      {
        "command": "sagefs.prevBlock",
        "title": "SageFs: Previous Code Block"
      },
      {
        "command": "sagefs.cancelEval",
        "title": "SageFs: Cancel Evaluation"
      },
      {
        "command": "sagefs.loadScript",
        "title": "SageFs: Load Current Script"
      }
    ],
    "keybindings": [
      {
        "command": "sagefs.eval",
        "key": "alt+enter",
        "when": "editorTextFocus && editorLangId == fsharp"
      },
      {
        "command": "sagefs.evalFile",
        "key": "alt+shift+enter",
        "when": "editorTextFocus && editorLangId == fsharp"
      },
      {
        "command": "sagefs.evalAdvance",
        "key": "shift+enter",
        "when": "editorTextFocus && editorLangId == fsharp && !notebookEditorFocused"
      },
      {
        "command": "sagefs.cancelEval",
        "key": "ctrl+shift+c",
        "when": "editorTextFocus && editorLangId == fsharp"
      },
      {
        "command": "sagefs.evalAllBlocks",
        "key": "ctrl+alt+enter",
        "when": "editorTextFocus && editorLangId == fsharp"
      },
      {
        "command": "sagefs.nextBlock",
        "key": "ctrl+down",
        "when": "editorTextFocus && editorLangId == fsharp"
      },
      {
        "command": "sagefs.prevBlock",
        "key": "ctrl+up",
        "when": "editorTextFocus && editorLangId == fsharp"
      }
    ],
    "configuration": {
      "title": "SageFs",
      "properties": {
        "sagefs.mcpPort": {
          "type": "number",
          "default": 37749,
          "description": "Port for the SageFs MCP server."
        },
        "sagefs.dashboardPort": {
          "type": "number",
          "default": 37750,
          "description": "Port for the SageFs dashboard."
        },
        "sagefs.autoStart": {
          "type": "boolean",
          "default": true,
          "description": "Automatically start SageFs daemon when opening an F# project."
        },
        "sagefs.projectPath": {
          "type": "string",
          "default": "",
          "description": "Path to .fsproj file. If empty, SageFs auto-detects."
        },
        "sagefs.logLevel": {
          "type": "string",
          "enum": [
            "error",
            "info",
            "debug"
          ],
          "default": "info",
          "description": "Output channel log level."
        },
        "sagefs.inlineResultTimeout": {
          "type": "number",
          "default": 30000,
          "description": "How long (ms) inline eval results stay visible before auto-clearing. Set to 0 to keep forever."
        },
        "sagefs.cellHighlight": {
          "type": "boolean",
          "default": true,
          "description": "Highlight the current code cell (block) the cursor is in."
        },
        "sagefs.density": {
          "type": "string",
          "enum": [
            "full",
            "normal",
            "minimal"
          ],
          "enumDescriptions": [
            "All decorations: inline results, code lens, cell highlight, test signs, stale markers",
            "Inline results and test signs, no code lens or cell highlight",
            "Only inline results on eval, nothing persistent"
          ],
          "default": "full",
          "description": "Controls how many visual annotations SageFs shows."
        },
        "sagefs.typeExplorerRoot": {
          "type": "string",
          "default": "",
          "description": "Root namespace for the Type Explorer tree. Empty string shows all top-level namespaces."
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "sagefs",
          "title": "SageFs",
          "icon": "$(flame)"
        }
      ]
    },
    "views": {
      "sagefs": [
        {
          "id": "sagefs-sessions",
          "name": "Sessions",
          "contextualTitle": "SageFs Sessions"
        },
        {
          "id": "sagefs-hotReload",
          "name": "Hot Reload Files",
          "contextualTitle": "SageFs Hot Reload"
        },
        {
          "id": "sagefs-sessionContext",
          "name": "Session Context",
          "contextualTitle": "SageFs Session Context"
        },
        {
          "id": "sagefs-types",
          "name": "Type Explorer",
          "contextualTitle": "SageFs Type Explorer"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "sagefs.hotReloadWatchAll",
          "when": "view == sagefs-hotReload",
          "group": "navigation"
        },
        {
          "command": "sagefs.hotReloadUnwatchAll",
          "when": "view == sagefs-hotReload",
          "group": "navigation"
        },
        {
          "command": "sagefs.hotReloadRefresh",
          "when": "view == sagefs-hotReload",
          "group": "navigation"
        },
        {
          "command": "sagefs.sessionContextRefresh",
          "when": "view == sagefs-sessionContext",
          "group": "navigation"
        },
        {
          "command": "sagefs.createSession",
          "when": "view == sagefs-sessions",
          "group": "navigation"
        },
        {
          "command": "sagefs.sessionsRefresh",
          "when": "view == sagefs-sessions",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "sagefs.switchToSession",
          "when": "view == sagefs-sessions && viewItem =~ /session-inactive/",
          "group": "inline"
        },
        {
          "command": "sagefs.resetSessionInline",
          "when": "view == sagefs-sessions && viewItem =~ /session-active/",
          "group": "inline"
        },
        {
          "command": "sagefs.stopSessionInline",
          "when": "view == sagefs-sessions && viewItem =~ /session-(active|inactive)/ && viewItem != session-stopped",
          "group": "inline"
        }
      ]
    },
    "colors": [
      {
        "id": "sagefs.successBackground",
        "description": "Background color for successful eval results",
        "defaults": {
          "dark": "#a6e3a120",
          "light": "#40a02b20",
          "highContrast": "#00ff0020"
        }
      },
      {
        "id": "sagefs.successForeground",
        "description": "Foreground color for successful eval results",
        "defaults": {
          "dark": "#a6e3a1",
          "light": "#40a02b",
          "highContrast": "#00ff00"
        }
      },
      {
        "id": "sagefs.errorBackground",
        "description": "Background color for eval errors",
        "defaults": {
          "dark": "#f38ba820",
          "light": "#d2004220",
          "highContrast": "#ff000020"
        }
      },
      {
        "id": "sagefs.errorForeground",
        "description": "Foreground color for eval errors",
        "defaults": {
          "dark": "#f38ba8",
          "light": "#d20042",
          "highContrast": "#ff0000"
        }
      },
      {
        "id": "sagefs.runningForeground",
        "description": "Foreground color for running indicator",
        "defaults": {
          "dark": "#f9e2af",
          "light": "#df8e1d",
          "highContrast": "#ffff00"
        }
      },
      {
        "id": "sagefs.outputForeground",
        "description": "Foreground color for output text",
        "defaults": {
          "dark": "#a6adc8",
          "light": "#6c6f85",
          "highContrast": "#ffffff"
        }
      },
      {
        "id": "sagefs.staleForeground",
        "description": "Foreground color for stale results",
        "defaults": {
          "dark": "#6c7086",
          "light": "#9ca0b0",
          "highContrast": "#808080"
        }
      },
      {
        "id": "sagefs.evalFlashBackground",
        "description": "Background highlight shown briefly when evaluating a code block",
        "defaults": {
          "dark": "#264f7830",
          "light": "#add8e630",
          "highContrast": "#ffffff20"
        }
      },
      {
        "id": "sagefs.cellHighlightBackground",
        "description": "Background color for the current code cell",
        "defaults": {
          "dark": "#ffffff06",
          "light": "#00000006",
          "highContrast": "#ffffff10"
        }
      },
      {
        "id": "sagefs.cellBorderColor",
        "description": "Border color for the top edge of the current code cell",
        "defaults": {
          "dark": "#ffffff15",
          "light": "#00000015",
          "highContrast": "#ffffff30"
        }
      }
    ],
    "snippets": [
      {
        "language": "fsharp",
        "path": "./snippets/fsharp.json"
      }
    ]
  },
  "scripts": {
    "sync-version": "node -e \"const fs=require('fs');const x=fs.readFileSync('../Directory.Build.props','utf8');const m=x.match(/<Version>([^<]+)<\\/Version>/);if(m){const p=JSON.parse(fs.readFileSync('package.json','utf8'));p.version=m[1];fs.writeFileSync('package.json',JSON.stringify(p,null,2)+'\\n');console.log('Version synced:',m[1])}\"",
    "vscode:prepublish": "npm run sync-version && npm run compile",
    "compile": "dotnet fable src --outDir fable-out && node esbuild.mjs",
    "watch": "dotnet fable watch src --outDir fable-out",
    "compile:ts": "tsc -p ./"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.24.2",
    "typescript": "^5.5.0"
  }
}
